# Copy to .env and fill in. `docker compose` auto-loads .env from the repo root.
# NEVER commit your real .env -- it is gitignored on purpose. Keys live only here,
# on your machine. This file ships safe localhost-oriented defaults and no secrets.
#
# Optional LLM provider for generated answers (Scrying / query answers), the research
# worker, and the index-time contextual chunker. BLANK BY DEFAULT: a plain
# `docker compose up` runs retrieval-only -- indexing, search, and compare all work,
# there are just no generated answers. To enable answers, point this at any
# OpenAI-compatible endpoint and set the key below. Common choices:
#   - a bundled model service on its own compose stack, reached over the host gateway
#     (the worker needs extra_hosts host-gateway): services/llm-endpoint (single
#     model, e.g. Gemma) at http://host.docker.internal:8097/v1, or
#     services/agent-server (allied multi-model router) -- see each service's README
#   - your own host-local GPU server, e.g. http://host.docker.internal:8081/v1
#   - a hosted provider's OpenAI-compatible endpoint
MADOSHO_LLM_API_BASE=

# API key for the provider above. For a local llama.cpp endpoint any non-empty
# value works (sk-noop). For a HOSTED provider, paste your key below in THIS
# local .env only -- never commit it:
MADOSHO_LLM_API_KEY=sk-noop

# Index-time LLM (contextual chunker) + eval/Scrying default. Seeds the llm_endpoint
# registry on first boot. Reference model = allied Gemma (see services/llm-endpoint).
# The seeded endpoint is registered as BOTH text and vision default, so one multimodal
# model (e.g. Gemma E4B) serves the contextual chunker, eval, Scrying answer, AND
# the extraction comparison head-to-head -- no second server required.
MADOSHO_INDEX_LLM_PROVIDER=openai
MADOSHO_INDEX_LLM_MODEL=gemma-4-e4b
# Auth. AUTH_ENABLED defaults ON (blank = on; set 0/false to disable). API_KEY is
# the worker's service key for calling the gated planes (and any legacy single-key
# clients). SESSION_SECRET signs the browser session cookie -- set a stable random
# value (e.g. `python -c "import secrets;print(secrets.token_urlsafe(48))"`) so
# logins survive restarts and validate across the app + query planes; blank falls
# back to a per-process random value. COOKIE_INSECURE=1 lets the cookie work over
# plain http (dev only); leave blank in production so the cookie stays Secure.
MADOSHO_AUTH_ENABLED=
MADOSHO_API_KEY=
MADOSHO_SESSION_SECRET=
MADOSHO_COOKIE_INSECURE=

# First admin login. Auth is ON by default, so a fresh `docker compose up` needs
# an account to get in. If BOTH are set and no active admin exists, the init
# one-shot seeds this admin on startup (idempotent). The defaults below let you log
# in at http://localhost:8080 right away with admin / admin -- CHANGE THE PASSWORD
# immediately after first login (Users page -> reset on your row). To mint keys for
# the CLI / MCP / agent tools, log in and use the Keys page (or the madosho-keys CLI).
# To add MORE accounts headless, use the CLI with a non-interactive password source:
#   MADOSHO_USER_PASSWORD=... madosho-users create --name bob --scope write
#   printf '%s' "$pw" | madosho-users create --name bob --scope read --password-stdin
MADOSHO_BOOTSTRAP_ADMIN_USER=admin
MADOSHO_BOOTSTRAP_ADMIN_PASSWORD=admin

# TLS overlay (examples/tls). The hostname or IP clients use to reach this
# machine over HTTPS -- Caddy issues its certificate for exactly this name.
# Only read when starting with the overlay:
#   docker compose -f compose.yaml -f compose.tls.yaml up
MADOSHO_TLS_HOST=localhost
