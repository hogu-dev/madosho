# Copy to .env and adjust if needed. These power the example llm-server compose.
# `docker compose` auto-loads .env from this directory.

# Host port the text-LLM endpoint listens on -- for your own curl testing. madosho itself
# reaches the server in-network as http://llm-server:8080/v1, not via this host port.
LLM_PORT=8096

# Host HuggingFace cache to share into the container (where `hf download` puts models).
# Defaults to the invoking user's ~/.cache/huggingface.
# HF_CACHE=/absolute/path/to/huggingface-cache   # if unset, compose defaults to ${HOME}/.cache/huggingface

# Run the container as your uid:gid so cached files stay owned by you, not root.
# Find yours with:  id -u ; id -g
PUID=1000
PGID=1000
