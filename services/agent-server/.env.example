# Copy to .env and adjust if needed. These power the example agent-server compose.
# `docker compose` auto-loads .env from this directory.

# Host port the text endpoint listens on -- for your own curl testing. The madosho worker
# reaches the server in-network as http://agent-server:8080/v1, not via this host port.
AGENT_PORT=8098

# Host HuggingFace cache to share into the container. Model weights download HERE on first
# use (never into the repo or an image) -- also where `hf download` / -hf put models.
# Defaults to the invoking user's ~/.cache/huggingface.
# HF_CACHE=/absolute/path/to/huggingface-cache   # if unset, compose defaults to ${HOME}/.cache/huggingface

# Run the container as your uid:gid so cached files stay owned by you, not root.
# Find yours with:  id -u ; id -g
PUID=1000
PGID=1000
